# ==============================================
#  C / C++ 编译生成文件（永久忽略）
# ==============================================
*.o
*.obj
*.exe
*.out
*.app
*.bin
*.elf
*.hex
*.lib
*.a
*.so
*.dll
*.dylib
*.pdb
*.ilk
*.exp

# 可执行文件输出目录
build/
Build/
out/
output/
bin/
Debug/
Release/
x64/
x86/

# ==============================================
#  VS Code 编辑器配置
# ==============================================
.vscode/
.vs/
*.code-workspace
*.user
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================================
#  Windows 系统垃圾文件
# ==============================================
Thumbs.db
Thumbs.db:encryptable
desktop.ini
Desktop.ini
$RECYCLE.BIN/
System Volume Information/

# ==============================================
#  日志、临时文件、缓存
# ==============================================
*.log
*.tmp
*.temp
*.cache
*.d
*.gcda
*.gcno

# ==============================================
#  编辑器备份/自动保存
# ==============================================
*~
.~*
*.bak
*.backup
*.swp
*.swo

# ==============================================
#  Git 仓库本身（防止嵌套仓库）
# ==============================================
.git/
.gitignore
!.gitignore

# ==============================================
#  其他语言/环境通用忽略
# ==============================================
node_modules/
.DS_Store
.env
.idea/